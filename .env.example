# AI Provider Setup
# Rename this file to .env and fill in your keys.

# Your API Key (Supports OpenRouter, Google AI Studio, OpenAI, Groq, etc.)
AI_API_KEY=your_api_key_here

# Base URL (Default is OpenRouter, change to native provider if needed)
# OpenRouter: https://openrouter.ai/api/v1
# Google AI Studio: https://generativelanguage.googleapis.com/v1beta/openai/
# OpenAI: https://api.openai.com/v1
# Groq: https://api.groq.com/openai/v1
AI_BASE_URL=https://openrouter.ai/api/v1

# Models
# Vision models are used for Dish & Pantry image analysis
VISION_MODEL=google/gemini-2.5-flash
FALLBACK_VISION_MODEL=qwen/qwen-2-vl-72b-instruct

# Text models are used for Recipe Reconstruction & Pantry Adaptation
TEXT_MODEL=google/gemini-2.5-flash
FALLBACK_TEXT_MODEL=meta-llama/llama-3.1-70b-instruct

# Configuration
TEMPERATURE=0.7
MAX_TOKENS=8000
TOP_P=1.0

# System
LOG_LEVEL=INFO
